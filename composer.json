{
    "name": "parseforartisans/laravel",
    "description": "Parse documents to Markdown from Laravel. The client SDK for parseforartisans.com.",
    "keywords": ["laravel", "pdf", "parsing", "markdown", "ocr", "documents"],
    "homepage": "https://parseforartisans.com",
    "license": "MIT",
    "authors": [
        {
            "name": "Peter Van Dijck",
            "email": "petervandijck@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "ParseForArtisans\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ParseForArtisans\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --parallel",
        "lint:check": "pint --parallel --test",
        "test": [
            "@lint:check",
            "@php vendor/bin/pest"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ParseForArtisans\\ParseServiceProvider"
            ],
            "aliases": {
                "Parse": "ParseForArtisans\\Facades\\Parse"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
